---
const spaPhotos = [
  { src: "/images/spa/spa-01.jpg", alt: "Interior do Magnific Spa" },
  { src: "/images/spa/spa-02.webp", alt: "Detalhes do Magnific Spa" },
  { src: "/images/spa/spa-03.jpg", alt: "Fachada do Magnific Spa" },
];
---

<section id="localizacao">
  <!-- ── MOBILE: info empilhada + imagem inteira abaixo ── -->
  <div class="block md:hidden">
    <div
      style="display:flex;flex-direction:column;align-items:center;gap:1.25rem;padding:2.5rem 1.5rem;text-align:center;"
    >
      <span
        style="font-family:var(--font-body);font-size:0.625rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:#13253e;background-color:rgba(255,255,255,0.75);border:1px solid rgba(19,37,62,0.2);padding:0.4rem 1.1rem;border-radius:9999px;display:inline-block;"
      >
        Onde eu atendo
      </span>
      <img
        src="/images/spa/magnific-logo.png"
        alt="Magnific Spa"
        style="height:clamp(95px,30vw,160px);max-width:90%;object-fit:contain;"
      />
      <span
        style="font-family:var(--font-body);font-size:0.625rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:#13253e;background-color:rgba(255,255,255,0.75);border:1px solid rgba(19,37,62,0.2);padding:0.4rem 1.1rem;border-radius:9999px;display:inline-block;"
      >
        Cuiabá - MT
      </span>
    </div>
    <div style="width:100%;height:220px;overflow:hidden;">
      <img
        src="/images/spa/spa-banner.png"
        alt="Magnific Spa"
        style="width:100%;height:100%;object-fit:cover;object-position:center;"
      />
    </div>
  </div>

  <!-- ── DESKTOP: parallax banner com overlay e layout horizontal ── -->
  <div
    class="parallax-banner hidden md:block relative w-full h-[300px] overflow-hidden bg-cover bg-center"
    style="background-image:url('/images/spa/spa-banner.png');background-attachment:scroll;"
  >
    <div class="absolute inset-0" style="background:rgba(255,255,255,0.55);">
    </div>
    <div
      class="absolute inset-0 flex items-center justify-between px-16 lg:px-24 pointer-events-none"
    >
      <span
        style="font-family:var(--font-body);font-size:0.625rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:#13253e;background-color:rgba(255,255,255,0.75);border:1px solid rgba(19,37,62,0.2);padding:0.4rem 1.1rem;border-radius:9999px;display:inline-block;"
      >
        Onde eu atendo
      </span>
      <span
        style="font-family:var(--font-body);font-size:0.625rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:#13253e;background-color:rgba(255,255,255,0.75);border:1px solid rgba(19,37,62,0.2);padding:0.4rem 1.1rem;border-radius:9999px;display:inline-block;"
      >
        Cuiabá - MT
      </span>
    </div>
    <div
      class="absolute inset-0 flex items-center justify-center pointer-events-none"
    >
      <img
        src="/images/spa/magnific-logo.png"
        alt="Magnific Spa"
        style="height:clamp(70px,10vw,150px);max-width:90%;object-fit:contain;opacity:1;"
      />
    </div>
  </div>

  <!-- ── Conteúdo: Bento Grid + endereço ── -->
  <div
    class="pt-16 pb-36 md:pt-15 md:pb-24 px-10 md:px-6 lg:px-8 mx-auto md:h-[100vh] md:flex md:flex-col"
    style="max-width:1228px;"
  >
    <!-- ── DESKTOP: Grid 2x2 com proporções exatas ── -->
    <div
      id="spa-bento"
      class="hidden md:grid md:flex-1 md:min-h-0"
      style="
        grid-template-columns: 630fr 530fr;
        grid-template-rows: 1fr 1.35fr;
        row-gap: 56px;
        column-gap: 56px;
      "
    >
      <!-- Imagem esquerda superior: 630x365 -->
      <div
        class="bento-cell"
        style="position:relative; border-radius:14px; overflow:hidden;"
      >
        {
          spaPhotos.map((photo, i) => (
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
              class={`bento-img${i === 0 ? " active" : ""}`}
            />
          ))
        }
        <div class="bento-overlay"></div>
      </div>

      <!-- Imagem direita superior: 530x365 (preenche a linha) -->
      <div
        class="bento-cell"
        style="position:relative; border-radius:14px; overflow:hidden;"
      >
        {
          spaPhotos.map((photo, i) => (
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
              class={`bento-img${i === 1 ? " active" : ""}`}
            />
          ))
        }
        <div class="bento-overlay"></div>
      </div>

      <!-- Texto + botão -->
      <div
        style="display:flex; flex-direction:column; justify-content:center; gap:2rem; align-self:center; padding-left:0.5rem;"
      >
        <div>
          <span
            style="font-family:var(--font-body);font-size:0.8125rem;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;color:var(--color-text-muted);"
          >
            Localização
          </span>
          <p
            style="font-family:var(--font-body);font-size:1.25rem;font-weight:400;line-height:1.7;color:var(--color-text);margin-top:1rem;"
          >
            R. Quatrocentos Jd Imperial, n 37 — Jardim Imperial,<br />
            Cuiabá - MT, 78075-670
          </p>
        </div>
        <a
          class="btn btn--ghost btn--sm"
          href="https://maps.google.com/?q=R.+Quatrocentos+Jd+Imperial+n+37+Jardim+Imperial+Cuiaba+MT"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>Como Chegar</span>
          <svg
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
      </div>

      <!-- Imagem direita inferior: 530x305 -->
      <div
        class="bento-cell"
        style="position:relative; border-radius:14px; overflow:hidden;"
      >
        {
          spaPhotos.map((photo, i) => (
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
              class={`bento-img${i === 2 ? " active" : ""}`}
            />
          ))
        }
        <div class="bento-overlay"></div>
      </div>
    </div>

    <!-- ── MOBILE: Grid empilhado ── -->
    <div
      id="spa-bento-mobile"
      class="grid md:hidden"
      style="
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 220px 150px;
        gap: 12px;
      "
    >
      <div
        class="bento-cell"
        style="position:relative; grid-column:1/3; border-radius:14px; overflow:hidden;"
      >
        {
          spaPhotos.map((photo, i) => (
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
              class={`bento-img${i === 0 ? " active" : ""}`}
            />
          ))
        }
        <div class="bento-overlay"></div>
      </div>
      <div
        class="bento-cell"
        style="position:relative; border-radius:14px; overflow:hidden;"
      >
        {
          spaPhotos.map((photo, i) => (
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
              class={`bento-img${i === 1 ? " active" : ""}`}
            />
          ))
        }
        <div class="bento-overlay"></div>
      </div>
      <div
        class="bento-cell"
        style="position:relative; border-radius:14px; overflow:hidden;"
      >
        {
          spaPhotos.map((photo, i) => (
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
              class={`bento-img${i === 2 ? " active" : ""}`}
            />
          ))
        }
        <div class="bento-overlay"></div>
      </div>
    </div>

    <!-- ── MOBILE: endereço ── -->
    <div class="flex flex-col gap-6 mt-10 md:hidden">
      <div>
        <span
          style="font-family:var(--font-body);font-size:0.6875rem;font-weight:600;letter-spacing:0.25em;text-transform:uppercase;color:var(--color-text-muted);"
        >
          Localização
        </span>
        <p
          style="font-family:var(--font-body);font-size:1.0625rem;font-weight:400;line-height:1.7;color:var(--color-text);margin-top:0.85rem;"
        >
          R. Quatrocentos Jd Imperial, n 37 — Jardim Imperial,<br />
          Cuiabá - MT, 78075-670
        </p>
      </div>
      <a
        class="btn btn--ghost btn--sm"
        href="https://maps.google.com/?q=R.+Quatrocentos+Jd+Imperial+n+37+Jardim+Imperial+Cuiaba+MT"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span>Como Chegar</span>
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style is:global>
  /* ── Fotos Bento: crossfade + Ken Burns ── */
  .bento-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transform: scale(1.08);
    transition:
      opacity 1.2s ease,
      transform 10s ease;
    will-change: opacity, transform;
  }
  .bento-img.active {
    opacity: 1;
    transform: scale(1);
  }
  #spa-bento > div:hover .bento-img.active,
  #spa-bento-mobile > div:hover .bento-img.active {
    transform: scale(1.05);
    transition:
      opacity 1.2s ease,
      transform 0.6s ease;
  }

  /* Gradiente na base de cada célula */
  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 55%,
      rgba(0, 0, 0, 0.15)
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ── Parallax Desktop ── */
  @media (min-width: 768px) {
    .parallax-banner {
      background-attachment: fixed !important;
    }
  }
</style>

<script is:inline>
  (function () {
    ["spa-bento", "spa-bento-mobile"].forEach(function (id) {
      var bento = document.getElementById(id);
      if (!bento) return;

      var cells = bento.querySelectorAll(".bento-cell");
      var delays = [4000, 5500, 7000];

      cells.forEach(function (cell, idx) {
        var imgs = Array.from(cell.querySelectorAll(".bento-img"));
        if (imgs.length < 2) return;

        var current = idx % imgs.length;

        setInterval(function () {
          imgs[current].classList.remove("active");
          current = (current + 1) % imgs.length;
          imgs[current].classList.add("active");
        }, delays[idx] || 4000);
      });
    });
  })();
</script>
