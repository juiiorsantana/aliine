---
// Header.astro - Navbar fixa com efeito de vidro (glassmorphism) ao rolar.
// Transparente sobre o Hero no topo; vira vidro translucido com texto escuro apos scroll.
const navLinks = [
  { label: "Sobre", href: "#sobre" },
  { label: "Galeria", href: "#galeria" },
  { label: "Procedimentos", href: "#procedimentos" },
  { label: "Localização", href: "#localizacao" },
];
---

<header id="site-header" class="site-nav" data-state="top">
  <nav class="site-nav__inner" aria-label="Navegação principal">
    <a href="/" class="site-nav__logo">Aliine Souza Nail Design</a>

    <ul class="site-nav__links hidden md:flex">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href} class="nav-link">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a href="#contato" class="btn btn--primary btn--sm site-nav__cta">
      <span>Agendar meu horário</span>
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
      </svg>
    </a>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;
    background: transparent;
    border-bottom: 1px solid transparent;
    box-shadow: none;
    transition:
      background 0.4s ease,
      backdrop-filter 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
  }

  @media (min-width: 768px) {
    .site-nav__inner {
      padding: 1.5rem 3rem;
    }
  }

  @media (min-width: 1024px) {
    .site-nav__inner {
      padding: 1.5rem 5rem;
    }
  }

  /* ---- Estado VIDRO (apos scroll) ---- */
  .site-nav.is-scrolled {
    background: rgba(255, 255, 255, 0.6);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    backdrop-filter: blur(16px) saturate(160%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 8px 30px rgba(26, 18, 12, 0.08);
  }

  /* leve realce no topo da barra de vidro */
  .site-nav.is-scrolled::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.9),
      transparent
    );
    pointer-events: none;
  }

  /* ---- Logo ---- */
  .site-nav__logo {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    line-height: 1;
    color: #ffffff;
    text-decoration: none;
    transition: color 0.4s ease, opacity 0.3s ease;
  }

  .site-nav__logo:hover {
    opacity: 0.85;
  }

  @media (min-width: 768px) {
    .site-nav__logo {
      font-size: 1.25rem;
    }
  }

  .site-nav.is-scrolled .site-nav__logo {
    color: var(--color-text);
  }

  /* ---- Links ---- */
  .site-nav__links {
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
    gap: 2.25rem;
  }

  .nav-link {
    position: relative;
    display: inline-block;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    padding-bottom: 4px;
    transition: color 0.4s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-accent);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    width: 100%;
  }

  .site-nav.is-scrolled .nav-link {
    color: var(--color-text);
  }

  /* CTA usa o sistema global .btn .btn--primary .btn--sm.
     No topo fica oculto (so logo + secoes); aparece apenas depois que a
     primeira secao passa, deslizando da direita para a esquerda. */
  .site-nav__cta {
    flex-shrink: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(28px);
    transition:
      opacity 0.5s ease,
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0.5s ease,
      background-color 0.35s ease,
      box-shadow 0.35s ease;
  }
  .site-nav.is-past-hero .site-nav__cta {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(0);
  }

  /* Quando visivel, o CTA e verde WhatsApp (com o icone ja presente) */
  .site-nav.is-past-hero .site-nav__cta.btn--primary {
    background-color: #25d366;
    box-shadow:
      0 4px 14px rgba(37, 211, 102, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.04);
  }
  .site-nav.is-past-hero .site-nav__cta.btn--primary:hover {
    background-color: #1ebe5b;
    box-shadow:
      0 14px 32px rgba(37, 211, 102, 0.5),
      0 4px 10px rgba(0, 0, 0, 0.06);
  }
  .site-nav.is-past-hero .site-nav__cta.btn--primary:active {
    box-shadow: 0 3px 10px rgba(37, 211, 102, 0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav,
    .site-nav__logo,
    .nav-link,
    .nav-link::after {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    if (!header) return;

    const THRESHOLD = 40;
    // Primeira secao (Hero) — o CTA so aparece depois que ela passa
    const firstSection =
      document.getElementById("hero") ||
      document.querySelector("main section, body > section");
    let ticking = false;

    function heroThreshold() {
      if (!firstSection) return 600;
      // Quando a primeira secao quase saiu de cena (descontando a navbar)
      return firstSection.offsetHeight - header.offsetHeight;
    }

    function update() {
      const y = window.scrollY;
      const scrolled = y > THRESHOLD;
      header.classList.toggle("is-scrolled", scrolled);
      header.classList.toggle("is-past-hero", y > heroThreshold());
      header.dataset.state = scrolled ? "scrolled" : "top";
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update(); // estado inicial no load
  })();
</script>
