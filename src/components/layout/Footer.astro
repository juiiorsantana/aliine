---
const year = new Date().getFullYear();

const navLinks = [
  { label: 'Sobre',         href: '#sobre' },
  { label: 'Galeria',       href: '#galeria' },
  { label: 'Procedimentos', href: '#procedimentos' },
  { label: 'Localização',   href: '#localizacao' },
  { label: 'Agendar',       href: '#contato' },
];

const instagramUrl = 'https://www.instagram.com/';
const whatsappUrl  = 'https://wa.me/';
const mapsUrl      = 'https://maps.google.com/?q=R.+Quatrocentos+Jd+Imperial+n+37+Jardim+Imperial+Cuiaba+MT';
---

<footer id="contato" class="footer">
  <div class="footer__inner">

    <!-- Ornamento de topo: filete · diamante · filete -->
    <div class="footer__ornament" aria-hidden="true">
      <span class="footer__rule"></span>
      <svg class="footer__diamond" viewBox="0 0 16 16" width="14" height="14">
        <path d="M8 0l3 5 5 3-5 3-3 5-3-5-5-3 5-3z" fill="currentColor" />
      </svg>
      <span class="footer__rule"></span>
    </div>

    <div class="footer__grid">

      <!-- Coluna 1 — Marca -->
      <div class="footer__col footer__col--brand">
        <span class="footer__brand">Aliine Souza Nail Design</span>
        <p class="footer__tagline">Esmaltação em gel de alto padrão</p>
        <p class="footer__pitch">
          Unhas impecáveis, cuidado artesanal e a discrição de um atendimento sob medida em Cuiabá.
        </p>

        <ul class="footer__social">
          <li>
            <a
              href={instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Abrir Instagram em nova aba"
              class="footer__social-link"
            >
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M7 2.8h10A4.2 4.2 0 0 1 21.2 7v10A4.2 4.2 0 0 1 17 21.2H7A4.2 4.2 0 0 1 2.8 17V7A4.2 4.2 0 0 1 7 2.8Z"/>
                <circle cx="12" cy="12" r="4.1" fill="none" stroke="currentColor" stroke-width="1.6"/>
                <circle cx="17.4" cy="6.6" r="1.2" fill="currentColor"/>
              </svg>
            </a>
          </li>
          <li>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Conversar no WhatsApp em nova aba"
              class="footer__social-link"
            >
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="currentColor" d="M12 2.2a9.7 9.7 0 0 0-8.3 14.7L2.2 21.8l4.9-1.3A9.7 9.7 0 1 0 12 2.2Zm0 1.8a7.9 7.9 0 0 1 6.7 12.1l-.2.3.7 2.6-2.7-.7-.3.2A7.9 7.9 0 1 1 12 4Zm-3 3.7c-.2 0-.5 0-.7.4-.2.4-.9 1-.9 2.3s1 2.7 1.1 2.9c.1.2 1.9 3 4.7 4.1 2.3.9 2.8.7 3.3.7.5-.1 1.6-.7 1.9-1.3.2-.6.2-1.2.2-1.3-.1-.1-.3-.2-.6-.3-.3-.2-1.6-.8-1.9-.9-.3-.1-.4-.1-.6.2-.2.3-.6.9-.8 1-.1.2-.3.2-.5.1-.3-.2-1.2-.5-2.2-1.4-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.4.1-.5l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.2-.6-1.5-.8-2-.2-.5-.4-.5-.6-.5h-.4Z"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Coluna 2 — Navegação -->
      <nav class="footer__col" aria-label="Navegação do rodapé">
        <h3 class="footer__heading">Navegação</h3>
        <ul class="footer__list">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Coluna 3 — Atendimento -->
      <div class="footer__col">
        <h3 class="footer__heading">Atendimento</h3>
        <address class="footer__address">
          <span class="footer__address-line footer__address-line--strong">Magnific Spa</span>
          <span class="footer__address-line">R. Quatrocentos Jd Imperial, n 37</span>
          <span class="footer__address-line">Jardim Imperial — Cuiabá, MT</span>
          <span class="footer__address-line">78075-670</span>
        </address>
        <a
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="footer__link footer__link--map"
        >Como chegar →</a>
      </div>

      <!-- Coluna 4 — CTA -->
      <div class="footer__col footer__col--cta">
        <h3 class="footer__heading">Agende seu horário</h3>
        <p class="footer__cta-text">
          Vagas limitadas para manter o cuidado individual de cada cliente.
        </p>
        <a class="btn btn--primary btn--sm" href="#contato">
          <span>Reservar horário</span>
        </a>
      </div>

    </div>

    <!-- Copyright -->
    <div class="footer__bottom">
      <small class="footer__copy">
        &copy; {year} Aliine Souza Nail Design. Todos os direitos reservados.
      </small>
    </div>

  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding: 4.5rem 1.5rem 2.25rem;
    color: var(--color-text);
    background:
      linear-gradient(
        180deg,
        var(--color-beige-light) 0%,
        var(--color-beige) 55%,
        #cdbeac 100%
      );
  }

  @media (min-width: 768px) {
    .footer {
      padding: 5.5rem 3rem 2.5rem;
    }
  }

  .footer__inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  /* ── Ornamento ── */
  .footer__ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-accent);
    margin-bottom: 3rem;
  }

  .footer__rule {
    height: 1px;
    width: clamp(2rem, 22vw, 9rem);
    background: linear-gradient(
      90deg,
      transparent,
      rgba(26, 26, 26, 0.18)
    );
  }

  .footer__rule:last-child {
    background: linear-gradient(
      270deg,
      transparent,
      rgba(26, 26, 26, 0.18)
    );
  }

  .footer__diamond {
    flex-shrink: 0;
  }

  /* ── Grid ── */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.75rem;
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.75rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1.6fr 1fr 1.2fr 1.2fr;
      gap: 2.5rem;
    }
  }

  .footer__col {
    display: flex;
    flex-direction: column;
  }

  /* ── Coluna marca ── */
  .footer__brand {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .footer__tagline {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
    margin-top: 0.65rem;
  }

  .footer__pitch {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-top: 1rem;
    max-width: 30ch;
  }

  /* ── Social ── */
  .footer__social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid rgba(26, 26, 26, 0.14);
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.35);
    transition:
      color 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease;
  }

  .footer__social-link:hover,
  .footer__social-link:focus-visible {
    color: #ffffff;
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    outline: none;
  }

  .footer__social-link:focus-visible {
    outline: 2px solid var(--color-accent-hover);
    outline-offset: 3px;
  }

  /* ── Títulos de coluna ── */
  .footer__heading {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  /* ── Listas / links ── */
  .footer__list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer__link {
    position: relative;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-text-muted);
    transition: color 0.25s ease;
  }

  .footer__link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .footer__link:hover::after,
  .footer__link:focus-visible::after {
    transform: scaleX(1);
  }

  .footer__link:focus-visible {
    outline: 2px solid var(--color-accent-hover);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .footer__link--map {
    margin-top: 1.1rem;
    font-weight: 500;
    color: var(--color-accent-hover);
  }

  /* ── Endereço ── */
  .footer__address {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-style: normal;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .footer__address-line--strong {
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }

  /* ── CTA ── */
  .footer__cta-text {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 1.4rem;
    max-width: 28ch;
  }

  .footer__col--cta .btn {
    align-self: flex-start;
  }

  /* ── Copyright ── */
  .footer__bottom {
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(26, 26, 26, 0.12);
    text-align: center;
  }

  .footer__copy {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__social-link,
    .footer__link,
    .footer__link::after {
      transition: color 0.2s ease, background-color 0.2s ease;
    }
    .footer__social-link:hover,
    .footer__social-link:focus-visible {
      transform: none;
    }
    .footer__link::after {
      display: none;
    }
  }
</style>
