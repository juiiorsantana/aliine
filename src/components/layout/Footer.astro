---
const socialLinks = [
  { label: 'Instagram', href: 'https://www.instagram.com/' },
  { label: 'WhatsApp',  href: 'https://wa.me/' },
];
---

<footer id="contato" class="bg-[var(--color-beige)] py-14 px-6 md:px-12">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">

    <div>
      <!-- Nome da marca: Libertinus Serif Display -->
      <span
        style="
          font-family: var(--font-heading);
          font-size: 1.2rem;
          font-weight: 400;
          letter-spacing: -0.01em;
          color: var(--color-text);
        "
      >Aliine Souza Nail Design</span>
      <!-- Tagline: Manrope Light -->
      <p
        style="
          font-family: var(--font-body);
          font-size: 0.8125rem;
          font-weight: 300;
          letter-spacing: 0.03em;
          color: var(--color-text-muted);
          margin-top: 0.25rem;
        "
      >Esmaltação em gel de alto padrão</p>
    </div>

    <ul class="flex items-center gap-8">
      {socialLinks.map((social) => (
        <li>
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            style="
              font-family: var(--font-body);
              font-size: 0.75rem;
              font-weight: 500;
              letter-spacing: 0.14em;
              text-transform: uppercase;
              color: var(--color-text-muted);
              transition: color 0.2s ease;
            "
            onmouseenter="this.style.color='var(--color-text)';"
            onmouseleave="this.style.color='var(--color-text-muted)';"
          >
            {social.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="max-w-5xl mx-auto mt-8 pt-6 border-t border-[var(--color-text)]/10 text-center">
    <small
      style="
        font-family: var(--font-body);
        font-size: 0.6875rem;
        font-weight: 400;
        letter-spacing: 0.05em;
        color: var(--color-text-muted);
      "
    >
      &copy; {new Date().getFullYear()} Aliine Souza Nail Design. Todos os direitos reservados.
    </small>
  </div>
</footer>

